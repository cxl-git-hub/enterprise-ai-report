# Application
APP_NAME=ai-service
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database (MySQL via asyncmy)
DATABASE_URL=mysql+asyncmy://report:report123456@localhost:3306/ai_report

# Redis
REDIS_URL=redis://:redis123456@localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ai-reports
MINIO_SECURE=false

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# JWT (must match backend)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Safety
SQL_MAX_ROWS=10000
SQL_MAX_JOINS=3
PROMPT_MAX_TOKENS=128000

# Cost Tracking
COST_PER_1K_PROMPT_TOKENS=0.005
COST_PER_1K_COMPLETION_TOKENS=0.015
