# Application
APP_NAME=ai-service
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database (MySQL via asyncmy)
DATABASE_URL=mysql+asyncmy://report:report123456@localhost:3306/ai_report

# Redis
REDIS_URL=redis://:redis123456@localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ai-reports
MINIO_SECURE=false

# =============================================================================
# LLM Configuration
# =============================================================================
# Provider options: openai | anthropic | ollama | vllm | azure | deepseek | zhipu | moonshot | qwen | custom
#
# Examples:
#   --- OpenAI ---
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-xxx
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o
#
#   --- DeepSeek ---
#   LLM_PROVIDER=deepseek
#   LLM_API_KEY=sk-xxx
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
#
#   --- Zhipu GLM (智谱) ---
#   LLM_PROVIDER=zhipu
#   LLM_API_KEY=your-zhipu-key
#   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   LLM_MODEL=glm-4
#
#   --- Moonshot (月之暗面) ---
#   LLM_PROVIDER=moonshot
#   LLM_API_KEY=sk-xxx
#   LLM_BASE_URL=https://api.moonshot.cn/v1
#   LLM_MODEL=moonshot-v1-8k
#
#   --- Qwen via DashScope (通义千问) ---
#   LLM_PROVIDER=qwen
#   LLM_API_KEY=sk-xxx
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_MODEL=qwen-max
#
#   --- Anthropic / Claude ---
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-xxx
#   LLM_BASE_URL=https://api.anthropic.com
#   LLM_MODEL=claude-sonnet-4-20250514
#
#   --- Ollama (Local) ---
#   LLM_PROVIDER=ollama
#   LLM_BASE_URL=http://localhost:11434
#   LLM_MODEL=llama3
#   LLM_API_KEY=   # Not needed for Ollama
#
#   --- vLLM (Local) ---
#   LLM_PROVIDER=vllm
#   LLM_BASE_URL=http://localhost:8000/v1
#   LLM_MODEL=meta-llama/Llama-3-8B
#   LLM_API_KEY=   # Usually not needed
#
#   --- Azure OpenAI ---
#   LLM_PROVIDER=azure
#   LLM_API_KEY=your-azure-key
#   LLM_BASE_URL=https://YOUR_RESOURCE.openai.azure.com
#   LLM_MODEL=gpt-4
#   LLM_API_VERSION=2024-02-01
#
#   --- Custom OpenAI-compatible endpoint ---
#   LLM_PROVIDER=custom
#   LLM_API_KEY=your-key
#   LLM_BASE_URL=http://your-server:8080/v1
#   LLM_MODEL=your-model-name

LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=120.0
LLM_API_VERSION=2024-02-01
# LLM_EXTRA_HEADERS={"X-Custom-Header": "value"}

# JWT (must match backend)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Safety
SQL_MAX_ROWS=10000
SQL_MAX_JOINS=3
PROMPT_MAX_TOKENS=128000

# Cost Tracking (USD per 1K tokens)
COST_PER_1K_PROMPT_TOKENS=0.005
COST_PER_1K_COMPLETION_TOKENS=0.015
