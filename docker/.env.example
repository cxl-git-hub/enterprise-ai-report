# =============================================================================
# Enterprise AI Report Platform - Docker Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Database ---
DB_ROOT_PASSWORD=root123456
DB_NAME=ai_report
DB_USER=report
DB_PASSWORD=report123456
DB_PORT=3306

# --- Redis ---
REDIS_PASSWORD=redis123456
REDIS_PORT=6379

# --- MinIO (Object Storage) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ai-reports
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Backend ---
BACKEND_PORT=8080
JWT_SECRET=change-this-to-a-secure-random-string

# --- AI Service ---
AI_SERVICE_PORT=8081

# --- Frontend ---
FRONTEND_PORT=3000

# =============================================================================
# LLM Configuration
# =============================================================================
# Provider: openai | anthropic | ollama | vllm | azure | deepseek | zhipu | moonshot | qwen | custom

# OpenAI (default)
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=120.0
LLM_API_VERSION=2024-02-01
# LLM_EXTRA_HEADERS={"X-Custom": "value"}

# DeepSeek (uncomment to use)
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# Ollama local (uncomment to use)
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://host.docker.internal:11434
# LLM_MODEL=llama3
# LLM_API_KEY=

# Anthropic / Claude (uncomment to use)
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-your-key
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-sonnet-4-20250514

# Azure OpenAI (uncomment to use)
# LLM_PROVIDER=azure
# LLM_API_KEY=your-azure-key
# LLM_BASE_URL=https://YOUR_RESOURCE.openai.azure.com
# LLM_MODEL=gpt-4
# LLM_API_VERSION=2024-02-01
